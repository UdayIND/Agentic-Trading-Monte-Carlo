# Copy to .env (local) or set in Vercel project env (production).
# Generate secrets with:  openssl rand -hex 32

DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"   # Neon connection string
INGEST_SECRET="<openssl rand -hex 32>"   # HMAC shared with the agent-side pusher
AGENT_TOKEN="<openssl rand -hex 32>"     # agent poll/report bearer token
CRON_SECRET="<openssl rand -hex 32>"     # Vercel cron bearer token
SESSION_SECRET="<openssl rand -hex 32>"  # operator session signing key
OPERATOR_PASSWORD="<a strong password>"  # MVP operator login (passkey/TOTP = roadmap)
NEXT_PUBLIC_PHASE="paper"                # "paper" shows the PAPER watermark; "live" hides it
